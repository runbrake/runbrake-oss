{
  "name": "runbrake-scanner",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm run build:ts && pnpm run build:go",
    "build:go": "GOCACHE=$PWD/.cache/go-build GOMODCACHE=$PWD/.cache/go-mod go build ./cmd/runbrake",
    "build:ts": "pnpm -r --if-present run build",
    "ci:check": "bash scripts/scanner-repo-ci-check.sh",
    "format": "prettier --write . && gofmt -w cmd internal",
    "format:check": "bash scripts/format-check.sh",
    "lint": "pnpm run lint:ts && pnpm run lint:go",
    "lint:go": "GOCACHE=$PWD/.cache/go-build GOMODCACHE=$PWD/.cache/go-mod go vet ./...",
    "lint:ts": "pnpm --filter @runbrake/contracts run build && pnpm -r --if-present run lint",
    "schema:check": "pnpm --filter @runbrake/contracts run schema:check",
    "test": "pnpm run test:ts && pnpm run test:go",
    "test:go": "GOCACHE=$PWD/.cache/go-build GOMODCACHE=$PWD/.cache/go-mod go test ./...",
    "test:ts": "pnpm -r --if-present run test"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "ajv": "^8.17.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  }
}
